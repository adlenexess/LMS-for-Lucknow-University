<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.lu.lms.controller.StudentDashboardController" spacing="20" stylesheets="@../application.css">
   <children>
      <Label text="Student Dashboard" style="-fx-font-size: 20px; -fx-font-weight: bold;" />
      <Label text="Available Books" />
      <HBox>
        <children>
          <ListView fx:id="booksList" prefHeight="150" HBox.hgrow="ALWAYS" />
          <Button fx:id="issueBtn" onAction="#handleIssue" text="Issue Selected" />
        </children>
      </HBox>
      <Label text="My Issues" />
      <HBox>
        <children>
          <ListView fx:id="issuesList" prefHeight="150" HBox.hgrow="ALWAYS" />
          <Button fx:id="returnBtn" onAction="#handleReturn" text="Return Selected" />
        </children>
      </HBox>
      <HBox alignment="CENTER">
        <children>
          <Button fx:id="logoutBtn" onAction="#handleLogout" text="Logout" />
        </children>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20" left="20" right="20" top="20" />
   </padding>
</VBox>
